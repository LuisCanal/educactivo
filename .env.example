# Variables para Cloudflare Pages (Settings → Environment variables)
# No subas .env al repo; copiá estos nombres al dashboard de Pages.

RESEND_API_KEY=re_xxxxxxxx
CONTACT_FROM="EDUCACTIVO <onboarding@resend.dev>"
CONTACT_TO=tu-correo@dominio.com

